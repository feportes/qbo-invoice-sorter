<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Inbound Review</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1400px; }
    .muted { color:#666; font-size:13px; }
    .q { font-family: ui-monospace, monospace; font-size:12px; }
    .right { text-align:right; }
    .card { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; margin-top:12px; }

    /* Scroll container */
    .table-wrap { overflow-x:auto; border:1px solid #eee; border-radius:12px; margin-top:12px; }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      min-width: 1200px; /* forces horizontal scroll instead of squishing */
    }

    th, td { border-bottom:1px solid #eee; padding:10px; text-align:left; vertical-align: top; }
    th { background:#fafafa; }

    /* Sticky header */
    thead th { position: sticky; top: 0; z-index: 4; }

    /* Sticky (freeze) product column */
    th.sticky-product, td.sticky-product {
      position: sticky;
      left: 0;
      z-index: 3;
      background: #fff;
    }

    /* Keep sticky cell background correct when row is highlighted */
    tr.suspicious td.sticky-product { background: #fff3cd; }
    tr.bad td.sticky-product { background: #ffe0e0; }

    /* Inputs */
    input[type="text"], input[type="number"] {
      width: 100%;
      box-sizing: border-box;
      padding: 6px 8px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 14px;
      min-width: 0;
    }

    /* Column widths (7 columns total) */
    th:nth-child(1), td:nth-child(1) { width: 55px; }   /* # */
    th:nth-child(2), td:nth-child(2) { width: 360px; }  /* Product */
    th:nth-child(3), td:nth-child(3) { width: 120px; }  /* Packages */
    th:nth-child(4), td:nth-child(4) { width: 140px; }  /* Net */
    th:nth-child(5), td:nth-child(5) { width: 140px; }  /* Gross */
    th:nth-child(6), td:nth-child(6) { width: 170px; }  /* Batch */
    th:nth-child(7), td:nth-child(7) { width: 360px; }  /* SKU */

    /* SKU autocomplete */
    .sku-wrap { position: relative; }
    .sku-suggestions {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 4px);
      max-height: 240px;
      overflow: auto;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 8px;
      box-shadow: 0 6px 18px rgba(0,0,0,0.08);
      list-style: none;
      margin: 0;
      padding: 6px 0;
      z-index: 10;
      display: none;
    }
    .sku-suggestions li { padding: 8px 10px; cursor: pointer; }
    .sku-suggestions li:hover { background:#f5f5f5; }
    .sku-clear { margin-top: 6px; font-size: 12px; color: #666; cursor: pointer; display: inline-block; }

    /* Suspicious row highlight */
    tr.suspicious td { background: #fff3cd; } /* yellow */
    tr.bad td { background: #ffe0e0; }        /* red */
  </style>
</head>

<body>
  <a href="/inventory/inbound">← Back</a>

  <% if (!doc) { %>
    <h1>Inbound Doc not found</h1>
    <div class="muted">This inbound doc ID does not exist in the database.</div>
    </body></html>
    <% return; %>
  <% } %>

  <h1>Inbound Doc #<%= doc.id %></h1>

  <% if (msg) { %><div class="card"><%= msg %></div><% } %>

  <div class="muted">
    Date: <span class="q"><%= doc.doc_date || '' %></span><br/>
    Container: <span class="q"><%= doc.container_no || '' %></span><br/>
    File: <span class="q"><%= doc.source_filename || '' %></span>
  </div>



  <div class="card muted">
    Rows highlighted:
    <div>- <b>Yellow</b>: suspicious (qty very small vs net, missing batch, KG mismatch, etc.)</div>
    <div>- <b>Red</b>: invalid (net &gt; gross, missing net/gross)</div>
  </div>

  <form method="POST" action="/inventory/inbound/<%= doc.id %>/apply">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th class="sticky-product">Product (editable)</th>
            <th class="right">Packages</th>
            <th class="right">Net kg</th>
            <th class="right">Gross kg</th>
            <th>Batch</th>
            <th>Map to SKU</th>
          </tr>
        </thead>

        <tbody>
          <% if (!lines || lines.length === 0) { %>
            <tr><td colspan="7" class="muted">No parsed lines were found for this PDF.</td></tr>
          <% } else { %>
            <% lines.forEach((ln, idx) => { %>
              <tr class="inbound-row"
                  data-qty="<%= ln.qty_packages ?? '' %>"
                  data-net="<%= ln.net_kg ?? '' %>"
                  data-gross="<%= ln.gross_kg ?? '' %>"
                  data-lot="<%= ln.lot_number ?? '' %>"
                  data-name="<%= (ln.raw_product_name || '') %>">

                <td class="q"><%= ln.line_no ?? '' %></td>

                <td class="sticky-product">
                  <input type="hidden" name="line_id" value="<%= ln.id %>"/>
                  <input type="text" name="raw_product_name" value="<%= ln.raw_product_name || '' %>"/>
                </td>

                <td class="right">
                  <input type="number" name="qty_packages" value="<%= (ln.qty_packages ?? '') %>"/>
                </td>

                <td class="right">
                  <input type="number" step="0.01" name="net_kg" value="<%= (ln.net_kg ?? '') %>"/>
                </td>

                <td class="right">
                  <input type="number" step="0.01" name="gross_kg" value="<%= (ln.gross_kg ?? '') %>"/>
                </td>

                <td>
                  <input type="text" name="lot_number" value="<%= ln.lot_number || '' %>"/>
                </td>

                <td>
                  <!-- Hidden sku_id submitted -->
                  <input type="hidden" name="sku_id" id="sku_id_<%= idx %>" value="<%= ln.sku_id || '' %>"/>

                  <div class="sku-wrap">
                    <input
                      id="sku_input_<%= idx %>"
                      type="text"
                      placeholder="Type to search SKU…"
                      autocomplete="off"
                      data-idx="<%= idx %>"
                      value="<%= (ln.sku_name || '') %>"
                    />
                    <ul class="sku-suggestions" id="sku_sug_<%= idx %>"></ul>
                  </div>

                  <div class="sku-clear" data-idx="<%= idx %>">Clear</div>

                  <div class="muted" style="margin-top:6px;">
                    <%= ln.sku_name ? ("Selected: " + ln.sku_name) : "Not mapped" %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <button type="submit">Save edits + mappings + create lots</button>
      <div class="muted" style="margin-top:8px;">
        Edits override parsing. This is the safe inspection workflow.
      </div>
    </div>
  </form>

  <script>
    // ---------------- SKU autocomplete ----------------
    const ALL_SKUS = <%- JSON.stringify((skus || []).map(s => ({ id: String(s.id), name: String(s.name) }))) %>;
    function norm(s) { return (s || '').toString().toLowerCase().trim(); }

    function renderSuggestions(idx, matches) {
      const ul = document.getElementById(`sku_sug_${idx}`);
      ul.innerHTML = '';
      if (!matches.length) { ul.style.display = 'none'; return; }
      for (const it of matches) {
        const li = document.createElement('li');
        li.textContent = it.name;
        li.dataset.id = it.id;
        li.dataset.name = it.name;
        ul.appendChild(li);
      }
      ul.style.display = 'block';
    }

    function hideSuggestions(idx) {
      const ul = document.getElementById(`sku_sug_${idx}`);
      if (ul) ul.style.display = 'none';
    }

    document.addEventListener('click', () => {
      document.querySelectorAll('.sku-suggestions').forEach(ul => ul.style.display = 'none');
    });

    document.querySelectorAll('input[id^="sku_input_"]').forEach(inp => {
      const idx = inp.dataset.idx;
      const ul = document.getElementById(`sku_sug_${idx}`);

      inp.addEventListener('input', () => {
        const q = norm(inp.value);
        if (!q) { hideSuggestions(idx); return; }
        const matches = ALL_SKUS.filter(s => norm(s.name).includes(q)).slice(0, 30);
        renderSuggestions(idx, matches);
      });

      inp.addEventListener('focus', () => {
        const q = norm(inp.value);
        if (!q) return;
        const matches = ALL_SKUS.filter(s => norm(s.name).includes(q)).slice(0, 30);
        renderSuggestions(idx, matches);
      });

      ul.addEventListener('click', (e) => {
        const li = e.target.closest('li');
        if (!li) return;
        document.getElementById(`sku_id_${idx}`).value = li.dataset.id;
        inp.value = li.dataset.name;
        hideSuggestions(idx);
      });
    });

    document.querySelectorAll('.sku-clear').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.dataset.idx;
        document.getElementById(`sku_id_${idx}`).value = '';
        const inp = document.getElementById(`sku_input_${idx}`);
        inp.value = '';
        hideSuggestions(idx);
      });
    });

    // ---------------- suspicious row highlighting ----------------
    function toNum(x) {
      const n = Number(x);
      return Number.isFinite(n) ? n : null;
    }

    document.querySelectorAll('tr.inbound-row').forEach(tr => {
      const qty = toNum(tr.dataset.qty);
      const net = toNum(tr.dataset.net);
      const gross = toNum(tr.dataset.gross);
      const lot = (tr.dataset.lot || '').trim();
      const name = (tr.dataset.name || '').trim();

      let suspicious = false;
      let bad = false;

      if (!lot) suspicious = true;
      if (!net || !gross) bad = true;
      if (net && gross && net > gross + 0.01) bad = true;
      if (qty !== null && net !== null && qty <= 5 && net >= 200) suspicious = true;

      const kgMatch = name.match(/(\d+(?:\.\d+)?)\s*KG\b/i);
      if (kgMatch && qty && net) {
        const unitKg = Number(kgMatch[1]);
        if (Number.isFinite(unitKg) && unitKg > 0) {
          const expected = qty * unitKg;
          const relErr = Math.abs(net - expected) / Math.max(1, expected);
          if (relErr > 0.20) suspicious = true;
        }
      }

      if (bad) tr.classList.add('bad');
      else if (suspicious) tr.classList.add('suspicious');
    });
  </script>
</body>
</html>