<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Inbound Review</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1100px; }
    .muted { color:#666; font-size:13px; }
    table { width:100%; border-collapse:collapse; margin-top:12px; }
    th, td { border-bottom:1px solid #eee; padding:10px; text-align:left; vertical-align: top; }
    th { background:#fafafa; }
    .q { font-family: ui-monospace, monospace; font-size:12px; }
    .right { text-align:right; }
    .card { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; margin-top:12px; }

    .sku-filter { width: 100%; padding: 6px 8px; margin-bottom: 6px; box-sizing: border-box; }
    .sku-select { width: 100%; padding: 6px 8px; box-sizing: border-box; }

    @media print {
      .no-print { display:none; }
      body { margin: 0; }
    }
  </style>
</head>
<body>
  <a href="/inventory/inbound">← Back</a>

  <% if (!doc) { %>
    <h1>Inbound Doc not found</h1>
    <div class="muted">This inbound doc ID does not exist in the database.</div>
    </body></html>
    <% return; %>
  <% } %>

  <h1>Inbound Doc #<%= doc.id %></h1>

  <% if (msg) { %><div class="card"><%= msg %></div><% } %>

  <div class="muted">
    Date: <span class="q"><%= doc.doc_date || '' %></span><br/>
    Container: <span class="q"><%= doc.container_no || '' %></span><br/>
    File: <span class="q"><%= doc.source_filename || '' %></span>
  </div>

  <form method="POST" action="/inventory/inbound/<%= doc.id %>/apply">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Raw product name</th>
          <th>Lot (Batch)</th>
          <th class="right">Packages</th>
          <th class="right">Net kg</th>
          <th class="right">Gross kg</th>
          <th style="min-width: 320px;">Map to SKU</th>
        </tr>
      </thead>
      <tbody>
        <% if (!lines || lines.length === 0) { %>
          <tr>
            <td colspan="7" class="muted">
              No parsed lines were found for this PDF. (Parsing regex may need adjustment.)
            </td>
          </tr>
        <% } else { %>
          <% lines.forEach((ln, idx) => { %>
            <tr>
              <td class="q"><%= ln.line_no ?? '' %></td>
              <td><%= ln.raw_product_name || '' %></td>
              <td class="q"><%= ln.lot_number || '' %></td>
              <td class="right"><%= (ln.qty_packages ?? '') %></td>
              <td class="right"><%= (ln.net_kg ?? '') %></td>
              <td class="right"><%= (ln.gross_kg ?? '') %></td>

              <td>
                <!-- This is what gets submitted -->
                <input type="hidden" name="line_id" value="<%= ln.id %>"/>

                <!-- Search box to filter the select -->
                <input
                  type="text"
                  class="sku-filter"
                  placeholder="Type to search SKU…"
                  data-select-id="sku_select_<%= idx %>"
                />

                <!-- The actual select submitted to server -->
                <select id="sku_select_<%= idx %>" name="sku_id" class="sku-select">
                  <option value="">-- not mapped --</option>
                  <% skus.forEach(s => { %>
                    <option
                      value="<%= s.id %>"
                      <%= (ln.sku_id == s.id ? 'selected' : '') %>
                    ><%= s.name %></option>
                  <% }) %>
                </select>

                <div class="muted" style="margin-top:6px;">
                  Tip: type “IQF”, “18KG”, “unsweet”, etc.
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>

    <div class="card">
      <button type="submit">Save mappings + create lots (and learn aliases)</button>
      <div class="muted" style="margin-top:8px;">
        This will: (1) save mappings, (2) store aliases automatically, (3) upsert lots into your lots table.
      </div>
    </div>
  </form>

  <script>
    // Simple client-side filtering of <select> options per row.
    // No libraries needed.
    (function () {
      function normalize(s) {
        return (s || '').toString().toLowerCase().trim();
      }

      document.querySelectorAll('.sku-filter').forEach(input => {
        const selectId = input.getAttribute('data-select-id');
        const select = document.getElementById(selectId);
        if (!select) return;

        // cache original options so we can restore after filtering
        const originalOptions = Array.from(select.options).map(o => ({
          value: o.value,
          text: o.text,
          selected: o.selected
        }));

        function applyFilter() {
          const q = normalize(input.value);

          // Keep current selection value
          const currentValue = select.value;

          // Rebuild options
          select.innerHTML = '';
          for (const opt of originalOptions) {
            // Always include "-- not mapped --"
            if (!opt.value) {
              const o = new Option(opt.text, opt.value, false, currentValue === opt.value);
              select.add(o);
              continue;
            }

            if (!q || normalize(opt.text).includes(q)) {
              const o = new Option(opt.text, opt.value, false, currentValue === opt.value);
              select.add(o);
            }
          }
        }

        input.addEventListener('input', applyFilter);
        // Optional: if you click into box, show all first
        input.addEventListener('focus', applyFilter);
      });
    })();
  </script>
</body>
</html>
