<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Inbound Review</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1100px; }
    .muted { color:#666; font-size:13px; }
    table { width:100%; border-collapse:collapse; margin-top:12px; }
    th, td { border-bottom:1px solid #eee; padding:10px; text-align:left; vertical-align: top; }
    th { background:#fafafa; }
    .q { font-family: ui-monospace, monospace; font-size:12px; }
    .right { text-align:right; }
    .card { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; margin-top:12px; }

    .sku-wrap { position: relative; }
    .sku-input {
      width: 100%;
      padding: 6px 8px;
      box-sizing: border-box;
    }
    .sku-suggestions {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 4px);
      max-height: 240px;
      overflow: auto;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 8px;
      box-shadow: 0 6px 18px rgba(0,0,0,0.08);
      list-style: none;
      margin: 0;
      padding: 6px 0;
      z-index: 10;
      display: none;
    }
    .sku-suggestions li {
      padding: 8px 10px;
      cursor: pointer;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sku-suggestions li:hover {
      background: #f5f5f5;
    }
    .sku-pill {
      display:inline-block;
      margin-top:6px;
      font-size:12px;
      color:#333;
      background:#f3f3f3;
      border:1px solid #e6e6e6;
      padding:3px 8px;
      border-radius:999px;
    }
    .sku-clear {
      margin-top: 6px;
      font-size: 12px;
      color: #666;
      cursor: pointer;
      display: inline-block;
    }
  </style>
</head>
<body>
  <a href="/inventory/inbound">← Back</a>

  <% if (!doc) { %>
    <h1>Inbound Doc not found</h1>
    <div class="muted">This inbound doc ID does not exist in the database.</div>
    </body></html>
    <% return; %>
  <% } %>

  <h1>Inbound Doc #<%= doc.id %></h1>

  <% if (msg) { %><div class="card"><%= msg %></div><% } %>

  <div class="muted">
    Date: <span class="q"><%= doc.doc_date || '' %></span><br/>
    Container: <span class="q"><%= doc.container_no || '' %></span><br/>
    File: <span class="q"><%= doc.source_filename || '' %></span>
  </div>

  <form method="POST" action="/inventory/inbound/<%= doc.id %>/apply">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Raw product name</th>
          <th>Lot (Batch)</th>
          <th class="right">Packages</th>
          <th class="right">Net kg</th>
          <th class="right">Gross kg</th>
          <th style="min-width: 360px;">Map to SKU</th>
        </tr>
      </thead>

      <tbody>
        <% if (!lines || lines.length === 0) { %>
          <tr><td colspan="7" class="muted">No parsed lines were found for this PDF.</td></tr>
        <% } else { %>
          <% lines.forEach((ln, idx) => { %>
            <tr>
              <td class="q"><%= ln.line_no ?? '' %></td>
              <td><%= ln.raw_product_name || '' %></td>
              <td class="q"><%= ln.lot_number || '' %></td>
              <td class="right"><%= (ln.qty_packages ?? '') %></td>
              <td class="right"><%= (ln.net_kg ?? '') %></td>
              <td class="right"><%= (ln.gross_kg ?? '') %></td>

              <td>
                <input type="hidden" name="line_id" value="<%= ln.id %>"/>

                <!-- Hidden value submitted -->
                <input type="hidden" name="sku_id" id="sku_id_<%= idx %>" value="<%= ln.sku_id || '' %>"/>

                <!-- Single bar the user types into -->
                <div class="sku-wrap">
                  <input
                    class="sku-input"
                    id="sku_input_<%= idx %>"
                    type="text"
                    placeholder="Type to search SKU…"
                    autocomplete="off"
                    data-idx="<%= idx %>"
                    value="<%= (ln.sku_name || '') %>"
                  />
                  <ul class="sku-suggestions" id="sku_sug_<%= idx %>"></ul>
                </div>

                <div class="sku-clear" data-idx="<%= idx %>">Clear</div>

                <% if (ln.sku_name) { %>
                  <div class="sku-pill">Selected: <%= ln.sku_name %></div>
                <% } else { %>
                  <div class="muted" style="margin-top:6px;">Not mapped</div>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>

    <div class="card">
      <button type="submit">Save mappings + create lots (and learn aliases)</button>
      <div class="muted" style="margin-top:8px;">
        This will: (1) save mappings, (2) store aliases automatically, (3) upsert lots into your lots table.
      </div>
    </div>
  </form>

  <script>
    // Make SKUs available to JS (id + name)
    const ALL_SKUS = <%- JSON.stringify((skus || []).map(s => ({ id: String(s.id), name: String(s.name) }))) %>;

    function norm(s) { return (s || '').toString().toLowerCase().trim(); }

    function renderSuggestions(idx, matches) {
      const ul = document.getElementById(`sku_sug_${idx}`);
      ul.innerHTML = '';

      if (!matches.length) {
        ul.style.display = 'none';
        return;
      }

      for (const it of matches) {
        const li = document.createElement('li');
        li.textContent = it.name;
        li.dataset.id = it.id;
        li.dataset.name = it.name;
        ul.appendChild(li);
      }

      ul.style.display = 'block';
    }

    function hideSuggestions(idx) {
      const ul = document.getElementById(`sku_sug_${idx}`);
      if (ul) ul.style.display = 'none';
    }

    // Click outside closes any open suggestion lists
    document.addEventListener('click', (e) => {
      document.querySelectorAll('.sku-suggestions').forEach(ul => ul.style.display = 'none');
    });

    document.querySelectorAll('.sku-input').forEach(inp => {
      const idx = inp.dataset.idx;

      inp.addEventListener('input', () => {
        const q = norm(inp.value);
        if (!q) { hideSuggestions(idx); return; }

        // filter + limit
        const matches = ALL_SKUS
          .filter(s => norm(s.name).includes(q))
          .slice(0, 30);

        renderSuggestions(idx, matches);
      });

      inp.addEventListener('focus', () => {
        // show suggestions immediately if there is text
        const q = norm(inp.value);
        if (!q) return;
        const matches = ALL_SKUS
          .filter(s => norm(s.name).includes(q))
          .slice(0, 30);
        renderSuggestions(idx, matches);
      });

      // pick from list
      const ul = document.getElementById(`sku_sug_${idx}`);
      ul.addEventListener('click', (e) => {
        const li = e.target.closest('li');
        if (!li) return;

        const skuId = li.dataset.id;
        const skuName = li.dataset.name;

        document.getElementById(`sku_id_${idx}`).value = skuId;
        inp.value = skuName;

        hideSuggestions(idx);
      });
    });

    // Clear button
    document.querySelectorAll('.sku-clear').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.dataset.idx;
        document.getElementById(`sku_id_${idx}`).value = '';
        document.getElementById(`sku_input_${idx}`).value = '';
        hideSuggestions(idx);
      });
    });
  </script>
</body>
</html>

