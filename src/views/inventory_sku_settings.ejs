<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>SKU Settings</title>
  <style>
    body { font-family: system-ui; margin: 24px; max-width: 1200px; }
    h1 { margin: 0 0 6px 0; }
    .muted { color:#666; font-size:13px; }
    a { color:#111; text-decoration:none; }
    .nav { margin-top: 10px; }
    .card { border:1px solid #ddd; border-radius: 12px; padding: 16px; margin-top: 14px; background:#fff; }
    button { padding:10px 14px; border-radius:10px; border:1px solid #333; background:#111; color:#fff; }
    table { border-collapse: collapse; width: 100%; margin-top: 12px; }
    th, td { border-bottom: 1px solid #eee; padding: 10px; text-align:left; vertical-align: middle; }
    th { background:#fafafa; position: sticky; top: 0; }
    input[type="number"], select {
      padding: 8px; border:1px solid #ddd; border-radius:10px; width: 100%;
    }
    .btn-small { padding:8px 10px; border-radius:10px; border:1px solid #333; background:#111; color:#fff; }
    .msg { margin-top: 12px; padding: 10px; border-radius: 10px; background: #f4f4f4; }
    .checkbox { transform: scale(1.1); }
    .qboid { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 12px; color:#333; }
    .w-220 { width:220px; }
    .w-160 { width:160px; }
    .w-90 { width:90px; }
    .bar { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
    .select-col { width: 70px; }
  </style>
</head>
<body>

<h1>SKU Settings</h1>
<div class="muted">
  Sync items from QuickBooks into your internal SKU list. Filter by category using the dropdown.
</div>

<div class="nav muted">
  <a href="/inventory/yard">Yard</a> |
  <a href="/inventory/map?c=1">Container Map</a> |
  <a href="/inventory/settings/containers">Container Settings</a> |
  <a href="/inventory/walkin">Walk-in</a> |
  <a href="/">Home</a>
</div>

<% if (msg) { %>
  <div class="msg"><%= msg %></div>
<% } %>

<div class="card">
  <div class="bar">
    <!-- Sync -->
    <form method="post" action="/inventory/settings/skus/sync">
      <button type="submit">Sync from QuickBooks</button>
    </form>

    <!-- Bulk actions -->
    <form method="post"
          action="/inventory/settings/skus/bulk"
          style="display:inline-flex; gap:8px; flex-wrap:wrap; align-items:center; margin-left:12px;">
      <input type="hidden" name="selectedCat" value="<%= selectedCat %>" />

      <button type="submit" name="action" value="active:off_all"
              style="background:#b00020; border-color:#b00020;">
        Deactivate ALL
      </button>

      <button type="submit" name="action" value="active:off">
        Deactivate this category
      </button>

      <button type="submit" name="action" value="active:on">
        Activate this category
      </button>

      <span class="muted" style="margin-left:6px;">(Optional)</span>

      <button type="submit" name="action" value="lot:on">
        Lot ON (this category)
      </button>

      <button type="submit" name="action" value="lot:off">
        Lot OFF (this category)
      </button>
    </form>

    <!-- Category filter -->
    <form method="get" action="/inventory/settings/skus" class="bar">
      <label class="muted"><b>Category filter:</b></label>

      <select name="cat" class="w-220" onchange="this.form.submit()">
        <option value="all" <%= (selectedCat === 'all') ? 'selected' : '' %>>All categories</option>
        <option value="uncategorized" <%= (selectedCat === 'uncategorized') ? 'selected' : '' %>>Uncategorized</option>
        <% (categories || []).forEach(c => { %>
          <option value="<%= c.id %>" <%= (String(selectedCat) === String(c.id)) ? 'selected' : '' %>>
            <%= c.name %>
          </option>
        <% }) %>
      </select>
    </form>

    <span class="muted">Tip: run <a href="/admin/sync">Admin Sync</a> to pull categories first.</span>
  </div>

  <!-- BULK SAVE FORM WRAPS TABLE -->
  <form method="post" action="/inventory/settings/skus/bulk-save">
    <input type="hidden" name="selectedCat" value="<%= selectedCat %>"/>

    <div style="display:flex; gap:10px; align-items:center; margin:12px 0;">
      <button type="submit">Save selected</button>
      <span class="muted">Tip: check the rows you changed, then click “Save selected”.</span>
    </div>

    <table>
      <thead>
        <tr>
          <th class="select-col">Select</th>
          <th>Name</th>
          <th class="w-160">QBO Item ID</th>
          <th class="w-90">Active</th>
          <th class="w-90">Lot</th>
          <th class="w-90">Organic</th>
          <th class="w-90">Unit</th>
          <th class="w-160">Pallet threshold</th>
          <th class="w-90">Save</th>
        </tr>
      </thead>

      <tbody>
        <% (skus || []).forEach(s => { %>
          <tr>
            <!-- Select this row -->
            <td class="select-col">
              <input class="checkbox" type="checkbox" name="selected_sku_ids" value="<%= s.id %>"/>
            </td>

            <td>
              <b><%= s.name %></b>
              <div class="muted">SKU #<%= s.id %></div>
            </td>

            <td class="qboid"><%= s.qbo_item_id || '' %></td>

            <td>
              <input class="checkbox" type="checkbox" name="active_<%= s.id %>" <%= s.active ? 'checked' : '' %> />
            </td>

            <td>
              <input class="checkbox" type="checkbox" name="is_lot_tracked_<%= s.id %>" <%= s.is_lot_tracked ? 'checked' : '' %> />
            </td>

            <td>
              <input class="checkbox" type="checkbox" name="is_organic_<%= s.id %>" <%= s.is_organic ? 'checked' : '' %> />
            </td>

            <td>
              <select name="unit_type_<%= s.id %>">
                <% ['unit','tub','case','bucket','box','pint','bag'].forEach(u => { %>
                  <option value="<%= u %>" <%= (s.unit_type === u) ? 'selected' : '' %>><%= u %></option>
                <% }) %>
              </select>
            </td>

            <td>
              <input type="number" step="0.01" min="0.10" max="1.00"
                     name="pallet_pick_threshold_<%= s.id %>"
                     placeholder="blank = default"
                     value="<%= (s.pallet_pick_threshold === null || typeof s.pallet_pick_threshold === 'undefined') ? '' : s.pallet_pick_threshold %>"/>
              <div class="muted">0.80 = 80%</div>
            </td>

            <td class="muted">Use bulk save</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </form>
</div>

</body>
</html>
