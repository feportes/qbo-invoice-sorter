<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Email Automation</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1200px; }
    .muted { color:#666; font-size:13px; }
    .card { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; margin-top:12px; }
    table { width:100%; border-collapse:collapse; margin-top:12px; }
    th, td { border-bottom:1px solid #eee; padding:10px; text-align:left; vertical-align: top; }
    th { background:#fafafa; position:sticky; top:0; }
    input[type="number"] { width:80px; padding:8px; border:1px solid #ddd; border-radius:10px; }
    input[type="text"] { padding:8px; border:1px solid #ddd; border-radius:10px; }
    button { padding:10px 14px; border-radius:10px; border:1px solid #333; background:#111; color:#fff; cursor:pointer; }
    .right { text-align:right; }
    .q { font-family: ui-monospace, monospace; font-size:12px; }
  </style>
</head>
<body>

<h1>Email Automation</h1>

<div style="margin: 10px 0;">
  <a href="/">â Home</a>
</div>

<div class="muted">
  Uses QuickBooks to send invoice emails automatically based on QBO EmailStatus + reminder schedule.
</div>

<div class="card">
  <h3 style="margin-top:0;">Run Now (testing)</h3>

  <form method="post" action="/admin/email-automation/run-now" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
    <label class="muted"><b>Start date</b></label>
    <input name="startDate" value="2025-01-01" />

    <label class="muted"><b>Max invoices</b></label>
    <input name="maxInvoices" value="2000" style="width:90px;" />

    <button type="submit" name="dry" value="1">Dry run (no emails)</button>
    <button type="submit" name="dry" value="0" onclick="return confirm('Send real emails now?')">Send now</button>
  </form>

  <div class="muted" style="margin-top:8px;">
    Dry run computes what would be emailed. âSend nowâ uses QuickBooks email.
  </div>
</div>

<!-- â Dry-run preview tables -->
<% if (previewSend && previewSend.length) { %>
  <div class="card">
    <h3 style="margin-top:0;">Dry run preview â Auto-send invoice (first <%= previewSend.length %>)</h3>
    <table>
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Customer</th>
          <th>Due</th>
          <th>EmailStatus</th>
          <th class="right">Balance</th>
        </tr>
      </thead>
      <tbody>
        <% previewSend.forEach(p => { %>
          <tr>
            <td class="q"><%= p.docNumber %></td>
            <td><%= p.customerName %></td>
            <td class="q"><%= p.dueDate %></td>
            <td class="q"><%= p.emailStatus %></td>
            <td class="right"><%= Number(p.balance || 0).toFixed(2).replace(/\.00$/,'') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<% if (previewPre && previewPre.length) { %>
  <div class="card">
    <h3 style="margin-top:0;">Dry run preview â Pre-due reminders (first <%= previewPre.length %>)</h3>
    <table>
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Customer</th>
          <th>Due</th>
          <th class="right">Balance</th>
        </tr>
      </thead>
      <tbody>
        <% previewPre.forEach(p => { %>
          <tr>
            <td class="q"><%= p.docNumber %></td>
            <td><%= p.customerName %></td>
            <td class="q"><%= p.dueDate %></td>
            <td class="right"><%= Number(p.balance || 0).toFixed(2).replace(/\.00$/,'') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<% if (previewPost && previewPost.length) { %>
  <div class="card">
    <h3 style="margin-top:0;">Dry run preview â Post-due reminders (first <%= previewPost.length %>)</h3>
    <table>
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Customer</th>
          <th>Due</th>
          <th class="right">Balance</th>
        </tr>
      </thead>
      <tbody>
        <% previewPost.forEach(p => { %>
          <tr>
            <td class="q"><%= p.docNumber %></td>
            <td><%= p.customerName %></td>
            <td class="q"><%= p.dueDate %></td>
            <td class="right"><%= Number(p.balance || 0).toFixed(2).replace(/\.00$/,'') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<div class="card">
  <% if (msg) { %><div class="muted"><b><%= msg %></b></div><% } %>

  <h3 style="margin-top:0;">Customers with automation enabled</h3>
  <table>
    <thead>
      <tr>
        <th>Customer</th>
        <th>Auto-send invoice</th>
        <th>Pre-due reminder</th>
        <th>Days before due</th>
        <th>Post-due reminder</th>
        <th>Days after due</th>
        <th>QBO Email</th>
        <th>Override Email</th>
        <th>CC Email</th>
      </tr>
    </thead>
    <tbody>
      <% if (!active || active.length === 0) { %>
        <tr><td colspan="6" class="muted">None enabled yet.</td></tr>
      <% } else { %>
        <% active.forEach(r => { %>
          <tr>
            <td><%= r.display_name %></td>
            <td><%= r.enabled_send_invoice ? 'Yes' : '' %></td>
            <td><%= r.enabled_reminder ? 'Yes' : '' %></td>
            <td><%= r.reminder_days_before_due %></td>
            <td><%= r.enabled_post_due_reminder ? 'Yes' : '' %></td>
            <td><%= r.post_due_days_after_due %></td>
          
          <td style="font-size:0.82em;color:#888"><%- r.qbo_email || '' %></td>
          <td><input type="text" name="override_email_<%- r.customer_id %>" value="<%- r.override_email || '' %>" placeholder="(use QBO)" style="width:150px;font-size:0.82em"></td>
          <td><input type="text" name="cc_email_<%- r.customer_id %>" value="<%- r.cc_email || '' %>" placeholder="CC (optional)" style="width:150px;font-size:0.82em"></td></tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<div class="card">
  <h3 style="margin-top:0;">All Customers (alphabetical)</h3>

  <form method="post" action="/admin/email-automation/save">
    <table>
      <thead>
        <tr>
          <th>Customer</th>
          <th class="muted">Auto-send invoice</th>
          <th class="muted">Pre-due reminder</th>
          <th class="muted">Days before due</th>
          <th class="muted">Post-due reminder</th>
          <th class="muted">Days after due</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
          <tr>
            <td>
              <%= r.display_name %>
              <input type="hidden" name="customer_id" value="<%= r.customer_id %>">
            </td>

            <td>
              <input type="checkbox"
                     name="enabled_send_invoice_<%= r.customer_id %>"
                     <%= r.enabled_send_invoice ? 'checked' : '' %> />
            </td>

            <td>
              <input type="checkbox"
                     name="enabled_reminder_<%= r.customer_id %>"
                     <%= r.enabled_reminder ? 'checked' : '' %> />
            </td>

            <td>
              <input type="number" min="1" max="30"
                     name="reminder_days_before_due_<%= r.customer_id %>"
                     value="<%= r.reminder_days_before_due %>">
            </td>

            <td>
              <input type="checkbox"
                     name="enabled_post_due_reminder_<%= r.customer_id %>"
                     <%= r.enabled_post_due_reminder ? 'checked' : '' %> />
            </td>

            <td>
              <input type="number" min="1" max="60"
                     name="post_due_days_after_due_<%= r.customer_id %>"
                     value="<%= r.post_due_days_after_due %>">
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div style="margin-top:12px;">
      <button type="submit">Save Settings</button>
    </div>
  </form>
</div>

</body>
</html>