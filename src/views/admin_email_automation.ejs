<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Email Automation</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1200px; }
    .muted { color:#666; font-size:13px; }
    .card { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; margin-top:12px; }
    table { width:100%; border-collapse:collapse; margin-top:12px; }
    th, td { border-bottom:1px solid #eee; padding:10px; text-align:left; }
    th { background:#fafafa; position:sticky; top:0; }
    input[type="number"] { width:80px; padding:8px; border:1px solid #ddd; border-radius:10px; }
    button { padding:10px 14px; border-radius:10px; border:1px solid #333; background:#111; color:#fff; cursor:pointer; }
  </style>
</head>
<body>

<h1>Email Automation</h1>
<div class="muted">
  Uses QuickBooks to send invoice emails automatically based on QBO EmailStatus + reminder schedule.
</div>

<div class="card">
  <% if (msg) { %><div class="muted"><b><%= msg %></b></div><% } %>

  <h3 style="margin-top:0;">Customers with automation enabled</h3>
  <table>
    <thead>
      <tr>
        <th>Customer</th>
        <th>Auto-send invoice</th>
        <th>Reminder</th>
        <th>Days before due</th>
      </tr>
    </thead>
    <tbody>
      <% if (!active || active.length === 0) { %>
        <tr><td colspan="4" class="muted">None enabled yet.</td></tr>
      <% } else { %>
        <% active.forEach(r => { %>
          <tr>
            <td><%= r.display_name %></td>
            <td><%= r.enabled_send_invoice ? 'Yes' : '' %></td>
            <td><%= r.enabled_reminder ? 'Yes' : '' %></td>
            <td><%= r.reminder_days_before_due %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<div class="card">
  <h3 style="margin-top:0;">All Customers (alphabetical)</h3>

  <form method="post" action="/admin/email-automation/save">
    <table>
      <thead>
        <tr>
          <th>Customer</th>
          <th class="muted">Auto-send invoice</th>
          <th class="muted">Reminder</th>
          <th class="muted">Days before due</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
          <tr>
            <td>
              <%= r.display_name %>
              <input type="hidden" name="customer_id" value="<%= r.customer_id %>">
            </td>
            <td>
              <input type="checkbox" name="enabled_send_invoice_<%= r.customer_id %>" <%= r.enabled_send_invoice ? 'checked' : '' %> />
            </td>
            <td>
              <input type="checkbox" name="enabled_reminder_<%= r.customer_id %>" <%= r.enabled_reminder ? 'checked' : '' %> />
            </td>
            <td>
              <input type="number" min="1" max="30" name="reminder_days_before_due_<%= r.customer_id %>" value="<%= r.reminder_days_before_due %>">
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div style="margin-top:12px;">
      <button type="submit">Save Settings</button>
    </div>
  </form>
</div>

</body>
</html>