<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Quick Add Pallet</title>
  <style>
    body { font-family: system-ui; margin: 24px; max-width: 700px; }
    label { display:block; margin-top: 14px; font-weight: 600; }
    select, input, textarea {
      width:100%;
      padding:10px;
      margin-top:4px;
      border:1px solid #ddd;
      border-radius:10px;
    }
    button {
      margin-top:18px;
      padding:12px 16px;
      border-radius:10px;
      border:1px solid #333;
      background:#111;
      color:#fff;
      font-size:15px;
    }
    .muted { color:#666; font-size:13px; }
    .error { background:#fee; border:1px solid #f99; padding:10px; border-radius:10px; margin-bottom:12px; }
    a { color:#111; text-decoration:none; }
  </style>
</head>
<body>

<h1>Quick Add Pallet</h1>
<p class="muted">This loads current inventory into a container slot or WALKIN (no typos).</p>

<% if (msg) { %>
  <div class="error"><%= msg %></div>
<% } %>

<form method="post">

  <label>SKU</label>
  <select name="sku_id" required>
    <% skus.forEach(s => { %>
      <option value="<%= s.id %>"><%= s.name %></option>
    <% }) %>
  </select>

  <label>Lot ID (optional — required only for organic)</label>
  <input name="lot_id" placeholder="Leave blank for non-tracked/local"/>

  <label>Pallet Config ID (optional)</label>
  <input name="pallet_config_id" placeholder="Optional"/>

  <label>Container</label>
  <select onchange="window.location.href='/inventory/add-pallet?c=' + this.value;">
    <% containers.forEach(c => { %>
      <option value="<%= c %>" <%= c===containerNo ? 'selected' : '' %>>C<%= c %></option>
    <% }) %>
  </select>

  <label>Slot</label>
  <select name="location_code" required>
    <% slotOptions.forEach(code => { %>
      <option value="<%= code %>"><%= code %></option>
    <% }) %>
    <option value="WALKIN">WALKIN</option>
    <option value="RETURNS">RETURNS</option>
  </select>

  <label>Quantity</label>
  <input name="qty_units" type="number" step="0.01" required/>

  <label>Notes</label>
  <textarea name="notes"></textarea>

  <button type="submit">Create Pallet</button>
</form>

<p style="margin-top:20px;">
  <a href="/inventory/map?c=<%= containerNo %>">Back to Container Map</a> |
  <a href="/">Home</a>
</p>

</body>
</html>
