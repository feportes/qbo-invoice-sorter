<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Container Mode Settings</title>
  <style>
    body { font-family: system-ui; margin: 24px; max-width: 820px; }
    h1 { margin-bottom: 8px; }
    .muted { color:#666; font-size: 13px; }
    .card { border:1px solid #ddd; border-radius: 12px; padding: 16px; margin-top: 14px; }
    label { display:block; margin-top: 12px; font-weight: 600; }
    select { width: 100%; padding: 10px; border:1px solid #ddd; border-radius: 10px; margin-top: 6px; }
    button { margin-top: 16px; padding: 12px 16px; border-radius: 10px; border:1px solid #333; background:#111; color:#fff; }
    .msg { margin-top: 12px; padding: 10px; border-radius: 10px; background: #f4f4f4; }
    a { color:#111; text-decoration:none; }
    .row { display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  </style>
</head>
<body>

  <h1>Container Mode Settings</h1>
  <div class="muted">
    Set how many pallet positions each container can display.
    Door = 01. Left/Right lanes.
  </div>

  <% if (msg) { %>
    <div class="msg"><%= msg %></div>
  <% } %>

  <div class="card">
    <form method="post">
      <label>C1 (20 ft) mode</label>
      <select name="mode_c1">
        <option value="8-slot" <%= current.C1 === '8-slot' ? 'selected' : '' %>>8-slot (L01–L04 / R01–R04)</option>
        <option value="10-slot" <%= current.C1 === '10-slot' ? 'selected' : '' %>>10-slot (L01–L05 / R01–R05)</option>
      </select>

      <div style="height:10px;"></div>
      <div class="row">
        <div>
          <label>C2 (40 ft) mode</label>
          <select name="mode_c2">
            <option value="18-slot" <%= current.C2 === '18-slot' ? 'selected' : '' %>>18-slot (L01–L09 / R01–R09)</option>
            <option value="20-slot" <%= current.C2 === '20-slot' ? 'selected' : '' %>>20-slot (L01–L10 / R01–R10)</option>
          </select>
        </div>

        <div>
          <label>C3 (40 ft) mode</label>
          <select name="mode_c3">
            <option value="18-slot" <%= current.C3 === '18-slot' ? 'selected' : '' %>>18-slot</option>
            <option value="20-slot" <%= current.C3 === '20-slot' ? 'selected' : '' %>>20-slot</option>
          </select>
        </div>

        <div>
          <label>C4 (40 ft) mode</label>
          <select name="mode_c4">
            <option value="18-slot" <%= current.C4 === '18-slot' ? 'selected' : '' %>>18-slot</option>
            <option value="20-slot" <%= current.C4 === '20-slot' ? 'selected' : '' %>>20-slot</option>
          </select>
        </div>

        <div>
          <label>C5 (40 ft) mode</label>
          <select name="mode_c5">
            <option value="18-slot" <%= current.C5 === '18-slot' ? 'selected' : '' %>>18-slot</option>
            <option value="20-slot" <%= current.C5 === '20-slot' ? 'selected' : '' %>>20-slot</option>
          </select>
        </div>

        <div>
          <label>C6 (40 ft) mode</label>
          <select name="mode_c6">
            <option value="18-slot" <%= current.C6 === '18-slot' ? 'selected' : '' %>>18-slot</option>
            <option value="20-slot" <%= current.C6 === '20-slot' ? 'selected' : '' %>>20-slot</option>
          </select>
        </div>

        <div>
          <label>C7 (40 ft) mode</label>
          <select name="mode_c7">
            <option value="18-slot" <%= current.C7 === '18-slot' ? 'selected' : '' %>>18-slot</option>
            <option value="20-slot" <%= current.C7 === '20-slot' ? 'selected' : '' %>>20-slot</option>
          </select>
        </div>
      </div>

      <button type="submit">Save</button>
    </form>
  </div>

  <p style="margin-top:16px;">
    <a href="/inventory/yard">Back to Yard</a> |
    <a href="/inventory/map?c=1">Container Map</a> |
    <a href="/">Home</a>
  </p>

</body>
</html>
