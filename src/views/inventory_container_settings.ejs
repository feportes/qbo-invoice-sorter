<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Container Layout Settings</title>
  <style>
    body { font-family: system-ui; margin: 24px; max-width: 980px; }
    h1 { margin: 0 0 6px 0; }
    .muted { color:#666; font-size: 13px; }
    .card { border:1px solid #ddd; border-radius: 12px; padding: 16px; margin-top: 14px; background:#fff; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border-bottom: 1px solid #eee; padding: 10px; text-align:left; vertical-align: top; }
    th { background:#fafafa; }
    select { width: 100%; padding: 8px; border:1px solid #ddd; border-radius: 10px; }
    button { margin-top: 16px; padding: 12px 16px; border-radius: 10px; border:1px solid #333; background:#111; color:#fff; }
    .msg { margin-top: 12px; padding: 10px; border-radius: 10px; background: #f4f4f4; }
    a { color:#111; text-decoration:none; }
    .nav { margin-top: 10px; }
    .small { font-size: 12px; color: #666; margin-top: 2px; }
    .pill { display:inline-block; padding:2px 8px; border-radius:999px; border:1px solid #ddd; background:#fff; font-size:12px; }
  </style>
</head>
<body>

<h1>Container Layout Settings</h1>
<div class="muted">Door side is <b>01</b>. Left/Right lanes are <b>L</b> and <b>R</b>.</div>

<div class="nav muted">
  <a href="/inventory/yard">Yard</a> |
  <a href="/inventory/map?c=1">Container Map</a> |
  <a href="/">Home</a>
</div>

<% if (msg) { %>
  <div class="msg"><%= msg %></div>
<% } %>

<div class="card">
  <form method="post">
    <table>
      <thead>
        <tr>
          <th style="width:90px;">Container</th>
          <th style="width:240px;">Mode</th>
          <th style="width:240px;">Flip</th>
          <th>Effective Layout</th>
        </tr>
      </thead>
      <tbody>

        <tr>
          <td><b>C1</b><div class="small">20 ft</div></td>
          <td>
            <select name="mode_C1">
              <option value="8-slot" <%= current.C1.mode === '8-slot' ? 'selected' : '' %>>8-slot (4/4)</option>
              <option value="9-slot" <%= current.C1.mode === '9-slot' ? 'selected' : '' %>>9-slot (5/4)</option>
            </select>
          </td>
          <td>
            <select name="flip_C1">
              <option value="L_LONG" <%= current.C1.flip === 'L_LONG' ? 'selected' : '' %>>Left longer (L>R)</option>
              <option value="R_LONG" <%= current.C1.flip === 'R_LONG' ? 'selected' : '' %>>Right longer (R>L)</option>
            </select>
            <div class="small">Flip matters only for 9-slot.</div>
          </td>
          <td><span class="pill"><%= current.C1.label %></span></td>
        </tr>

        <% ['C2','C3','C4','C5','C6','C7'].forEach(cn => { %>
          <tr>
            <td><b><%= cn %></b><div class="small">40 ft</div></td>
            <td>
              <select name="mode_<%= cn %>">
                <option value="18-slot" <%= current[cn].mode === '18-slot' ? 'selected' : '' %>>18-slot (9/9)</option>
                <option value="20-slot" <%= current[cn].mode === '20-slot' ? 'selected' : '' %>>20-slot (11/9)</option>
              </select>
            </td>
            <td>
              <select name="flip_<%= cn %>">
                <option value="L_LONG" <%= current[cn].flip === 'L_LONG' ? 'selected' : '' %>>Left longer (L>R)</option>
                <option value="R_LONG" <%= current[cn].flip === 'R_LONG' ? 'selected' : '' %>>Right longer (R>L)</option>
              </select>
              <div class="small">Flip matters only for 20-slot.</div>
            </td>
            <td><span class="pill"><%= current[cn].label %></span></td>
          </tr>
        <% }) %>

      </tbody>
    </table>

    <button type="submit">Save</button>
  </form>
</div>

</body>
</html>
