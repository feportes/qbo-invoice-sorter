<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Inventory Map - C<%= containerNo %></title>
  <style>
    body { font-family: system-ui; margin: 24px; }
    .top { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
    select, input { padding:8px; border:1px solid #ddd; border-radius:10px; }
    button { padding:8px 12px; border-radius:10px; border:1px solid #333; background:#111; color:#fff; }
    a { color:#111; text-decoration:none; }
    .grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:18px; max-width:1000px; }
    .col { border:1px solid #ddd; border-radius:12px; padding:12px; }
    .slot { border:1px solid #eee; border-radius:12px; padding:10px; margin-bottom:10px; }
    .slot.drop-hover { outline: 2px dashed #111; }
    .code { font-weight:700; }
    .muted { color:#666; font-size:13px; }
    .pallet { margin-top:6px; }
    .actions { display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; align-items:center; }
    .pill { display:inline-block; padding:2px 8px; border-radius:999px; border:1px solid #ddd; font-size:12px; margin-left:6px; }
    .draggable { cursor: grab; }
    .dropzone { border:2px dashed #bbb; border-radius:12px; padding:10px; }
    .dropzone.drop-hover { border-color:#111; }
  </style>
</head>
<body>

<div class="top">
  <h1 style="margin:0;">Container Map: C<%= containerNo %></h1>

  <% if (containerNo === 1 && c1Mode) { %>
    <span class="muted"><b>C1 Mode:</b> <%= c1Mode %> (L01–L05 / R01–R05)</span>
  <% } %>

  <form method="get" action="/inventory/map">
    <label class="muted">Container</label>
    <select name="c" onchange="this.form.submit()">
      <% containers.forEach(c => { %>
        <option value="<%= c %>" <%= c===containerNo ? "selected":"" %>>C<%= c %></option>
      <% }) %>
    </select>
  </form>

  <a href="/inventory/add-pallet?c=<%= containerNo %>">+ Add Pallet</a>
  <span class="muted">|</span>
  <a href="/inventory/walkin">Walk-in</a>
  <span class="muted">|</span>
  <a href="/">Home</a>
</div>

<p class="muted">
  Tip: Drag a pallet card and drop it onto another slot (same container) or onto WALKIN below.
  For moving to a different container, use the dropdown move for now.
</p>

<div class="dropzone" id="walkinDrop" data-slot="WALKIN">
  <b>Drop Here → WALKIN</b>
  <div class="muted">Drag a pallet here to move it to the walk-in.</div>
</div>

<div class="grid">

  <!-- LEFT -->
  <div class="col">
    <h3>LEFT (L) <span class="muted">01 = closest to door</span></h3>

    <% left.forEach(s => { %>
      <div class="slot" data-slot="<%= s.code %>">
        <div class="code"><%= s.code %></div>

       <% if (!s.pallet) { %>
  <div class="muted">Empty</div>
<% } else { %>
  <div class="pallet draggable" draggable="true" data-pallet-id="<%= s.pallet.id %>">
    <div>
      <b>Pallet #<%= s.pallet.id %></b>
      <span class="pill"><%= s.pallet.status %></span>
    </div>
    <div class="muted">
      <%= s.pallet.sku_name %>
      <% if (s.pallet.lot_number) { %> • Lot <%= s.pallet.lot_number %><% } %>
      • Qty: <%= s.pallet.qty_units %> <%= s.pallet.unit_type %>
    </div>

    <div class="actions">
      <!-- Move whole pallet -->
      <form method="post" action="/inventory/move">
        <input type="hidden" name="pallet_id" value="<%= s.pallet.id %>"/>
        <input type="hidden" name="container_no" value="<%= containerNo %>"/>

        <select name="to_slot" required>
          <% slotOptions.forEach(code => { %>
            <option value="<%= code %>"><%= code %></option>
          <% }) %>
        </select>

        <button>Move</button>
      </form>

      <!-- Break qty into WALKIN -->
      <form method="post" action="/inventory/break-to-walkin">
        <input type="hidden" name="pallet_id" value="<%= s.pallet.id %>"/>
        <input type="hidden" name="container_no" value="<%= containerNo %>"/>
        <input name="qty" type="number" step="0.01" min="0.01" placeholder="Qty"/>
        <button>Break → WALKIN</button>
      </form>
    </div>
  </div>
<% } %>
</div>
<% }) %>
</div>

<!-- RIGHT -->
<div class="col">
<h3>RIGHT (R) <span class="muted">01 = closest to door</span></h3>

<% right.forEach(s => { %>
<div class="slot" data-slot="<%= s.code %>">
  <div class="code"><%= s.code %></div>

  <% if (!s.pallet) { %>
    <div class="muted">Empty</div>
  <% } else { %>
    <div class="pallet draggable" draggable="true" data-pallet-id="<%= s.pallet.id %>">
      <div>
        <b>Pallet #<%= s.pallet.id %></b>
        <span class="pill"><%= s.pallet.status %></span>
      </div>
      <div class="muted">
        <%= s.pallet.sku_name %>
        <% if (s.pallet.lot_number) { %> • Lot <%= s.pallet.lot_number %><% } %>
        • Qty: <%= s.pallet.qty_units %> <%= s.pallet.unit_type %>
      </div>

      <div class="actions">
        <!-- Move whole pallet -->
        <form method="post" action="/inventory/move">
          <input type="hidden" name="pallet_id" value="<%= s.pallet.id %>"/>
          <input type="hidden" name="container_no" value="<%= containerNo %>"/>

          <select name="to_slot" required>
            <% slotOptions.forEach(code => { %>
              <option value="<%= code %>"><%= code %></option>
            <% }) %>
          </select>

          <button>Move</button>
        </form>

        <!-- Break qty into WALKIN -->
        <form method="post" action="/inventory/break-to-walkin">
          <input type="hidden" name="pallet_id" value="<%= s.pallet.id %>"/>
          <input type="hidden" name="container_no" value="<%= containerNo %>"/>
          <input name="qty" type="number" step="0.01" min="0.01" placeholder="Qty"/>
          <button>Break → WALKIN</button>
        </form>
      </div>
    </div>
  <% } %>
</div>
<% }) %>
</div>

</div>

<!-- Drag-drop to WALKIN dropzone (optional) -->
<div id="walkinDrop" class="slot" data-slot="WALKIN" style="margin-top:16px; max-width:420px;">
  <div class="code">WALKIN (drop pallet here)</div>
  <div class="muted">Drag any pallet and drop here to move the whole pallet into WALKIN.</div>
</div>

<script>
  let draggedPalletId = null;

  function postMove(palletId, toSlot) {
    return fetch('/inventory/move-json', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pallet_id: palletId, to_slot: toSlot })
    });
  }

  document.querySelectorAll('.draggable').forEach(el => {
    el.addEventListener('dragstart', (e) => {
      draggedPalletId = el.dataset.palletId;
      e.dataTransfer.setData('text/plain', draggedPalletId);
      e.dataTransfer.effectAllowed = 'move';
    });
  });

  function makeDroppable(node) {
    if (!node) return;

    node.addEventListener('dragover', (e) => {
      e.preventDefault();
      node.classList.add('drop-hover');
      e.dataTransfer.dropEffect = 'move';
    });

    node.addEventListener('dragleave', () => {
      node.classList.remove('drop-hover');
    });

    node.addEventListener('drop', async (e) => {
      e.preventDefault();
      node.classList.remove('drop-hover');

      const palletId = e.dataTransfer.getData('text/plain') || draggedPalletId;
      const toSlot = node.dataset.slot;

      if (!palletId || !toSlot) return;

      const resp = await postMove(palletId, toSlot);
      const json = await resp.json().catch(() => null);

      if (!resp.ok || !json?.ok) {
        alert('Move failed: ' + (json?.error || resp.statusText));
        return;
      }
      window.location.reload();
    });
  }

  document.querySelectorAll('.slot').forEach(makeDroppable);
  makeDroppable(document.getElementById('walkinDrop'));
</script>

</body>
</html>

