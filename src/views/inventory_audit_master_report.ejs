<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Organic Master Lot Report</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1100px; }
    h1, h2, h3 { margin-bottom:6px; }
    .muted { color:#666; font-size:13px; }
    .q { font-family: ui-monospace, monospace; font-size:12px; }
    .card { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; margin-top:18px; }
    table { width:100%; border-collapse:collapse; margin-top:10px; }
    th, td { border-bottom:1px solid #eee; padding:8px; text-align:left; }
    th { background:#fafafa; }
    .right { text-align:right; }
    .sku-header { background:#f3f6ff; padding:8px; border-radius:8px; margin-top:20px; }
    .lot-header { background:#f9f9f9; padding:6px; border-radius:6px; margin-top:12px; }
    @media print {
      .no-print { display:none; }
      body { margin:0; }
    }
  </style>
</head>
<body>

<div class="no-print" style="display:flex; gap:10px; align-items:center;">
  <a href="/inventory/audit/search">← Back</a>
  <button onclick="window.print()" style="padding:8px 14px; border-radius:8px; border:1px solid #333; background:#111; color:#fff; cursor:pointer;">
    Print / Save PDF
  </button>
</div>

<h1>Organic Master Lot Report</h1>

<div class="muted">
  Date range:
  <span class="q"><%= startDate %></span>
  to
  <span class="q"><%= endDate || '(open)' %></span>
</div>

<div class="card">
  <h2>Grand Total: <%= grandTotal.toFixed(2).replace(/\.00$/,'') %></h2>
</div>

<% if (!skuGroups || skuGroups.length === 0) { %>
  <div class="card muted">No audit allocations found.</div>
<% } %>

<% skuGroups.forEach(sku => { %>

  <div class="sku-header">
    <h2><%= sku.sku_name %></h2>
    <div class="muted">
      Unit: <span class="q"><%= sku.unit_type %></span> |
      SKU Total: <b><%= sku.skuTotal.toFixed(2).replace(/\.00$/,'') %></b>
    </div>
  </div>

  <% sku.lotsArr.forEach(lot => { %>

    <div class="lot-header">
      <h3>Lot: <%= lot.lot_number %></h3>
      <div class="muted">
        Lot Total: <b><%= lot.lotTotal.toFixed(2).replace(/\.00$/,'') %></b>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Invoice</th>
          <th>Customer</th>
          <th class="right">Qty</th>
        </tr>
      </thead>
      <tbody>
        <% lot.invoices.forEach(inv => { %>
          <tr>
            <td class="q"><%= inv.txn_date %></td>
            <td class="q"><%= inv.qbo_invoice_id %></td>
            <td><%= inv.customer_name %></td>
            <td class="right"><%= inv.qty_units.toFixed(2).replace(/\.00$/,'') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

  <% }) %>

<% }) %>

</body>
</html>
