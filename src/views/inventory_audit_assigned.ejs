<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Assigned Allocations</title>
  <style>
    body { font-family: system-ui; margin:24px; max-width:1200px; }
    table { width:100%; border-collapse:collapse; margin-top:12px; }
    th, td { border-bottom:1px solid #eee; padding:10px; text-align:left; }
    th { background:#fafafa; }
    .right { text-align:right; }
    .muted { color:#666; font-size:13px; }
  </style>
</head>
<body>

<h1>Assigned Allocations – <%= sku.name %></h1>
<div class="muted">Review or reassign lots if needed.</div>

<table>
  <thead>
    <tr>
      <th>Date</th>
      <th>Invoice</th>
      <th>Customer</th>
      <th>Lot</th>
      <th class="right">Qty</th>
      <th>Method</th>
    </tr>
  </thead>
  <tbody>
    <% if (!rows || rows.length === 0) { %>
      <tr><td colspan="6" class="muted">No assigned allocations.</td></tr>
    <% } else { %>
      <% rows.forEach(r => { %>
        <tr>
          <td><%= r.txn_date || '' %></td>
          <td><%= r.qbo_invoice_id %></td>
          <td><%= r.customer_name || '' %></td>
          <td><%= r.lot_number || 'UNKNOWN LOT' %></td>
          <td class="right"><%= Number(r.qty_units || 0).toFixed(2).replace(/\.00$/,'') %></td>
          <td><%= r.method %></td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

</body>
</html>